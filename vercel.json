{
  "buildCommand": "cd api && npm install",
  "outputDirectory": ".",
  "framework": null,
  "installCommand": "cd api && npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}